# ModelRouter environment
# Copy to .env and fill in values (or use secrets.yaml + 1Password)

MODELROUTER_HOST=127.0.0.1
MODELROUTER_PORT=3000
MODELROUTER_WORKERS=2

# Homelab SSH alias for deploy/push (optional — else read from config/hosts.local.yaml)
# MODELROUTER_REMOTE_HOST=gateway-mini

# Gateway master key — clients use this (must start with sk-)
MODELROUTER_MASTER_KEY=sk-modelrouter-change-me

# Required for encrypting stored keys in DB (Docker/production)
LITELLM_SALT_KEY=sk-modelrouter-salt-change-me

# Provider API keys (skip if using 1Password via secrets.yaml)
# Run: ./scripts/sync-keys.sh to fill from other projects on this machine
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=

# Non-LLM (documented in docs/API_INVENTORY.md)
CURSOR_API_KEY=
POLYGON_API_KEY=

# Local Ollama
OLLAMA_API_BASE=http://127.0.0.1:11434

# Redis (optional — enables caching + shared rate limits)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Postgres (optional — Docker stack sets this automatically)
# DATABASE_URL=   # leave unset for minimal mode (no Postgres)
POSTGRES_PASSWORD=modelrouter

# 1Password
OP_ACCOUNT=
