# Drop into any repo as .env.modelrouter (or merge into .env)
# Gateway — OpenAI-compatible; use preset names as model= (not vendor IDs)

OPENAI_API_BASE=http://127.0.0.1:3000/v1
OPENAI_BASE_URL=http://127.0.0.1:3000/v1
OPENAI_API_KEY=your-MODELROUTER_MASTER_KEY-or-project-key

# Optional: default preset hint for your agent
# MODELROUTER_PRESET_ROUTINE=cheap
# MODELROUTER_PRESET_COMPLEX=smart

# Homelab runtime host (no provider keys — gateway holds secrets):
# OPENAI_API_BASE=http://gateway.local:3000/v1
