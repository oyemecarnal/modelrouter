{
  "app_name": "ModelRouter Keys",
  "providers": {
    "openai-codex": true,
    "cursor": true,
    "anthropic": true,
    "gemini": true,
    "openrouter": true,
    "github-copilot": true,
    "groq": true,
    "mistral": true
  },
  "show_configured_keys": true,
  "dev_root": "/Users/kevinreed/dev",
  "modelrouter_root": "/Users/kevinreed/dev/modelrouter",
  "widget_on_top": false,
  "widget_size": 500,
  "refresh_interval_seconds": 120,
  "session_cache_days": 30,
  "widget_fetch_in_panel": true,
  "portfolio": {
    "enabled": false,
    "note": "Equity/wallets belong in project_kc — set equity.enabled true to opt in"
  },
  "watchdog_enabled": true,
  "edit_file": ".env.local",
  "equity": {
    "enabled": false,
    "remote_host": "kc-mini-lan",
    "coinbot_root": "/Users/kevinreed/dev/coinbot",
    "dev_root": "/Users/kevinreed/dev",
    "brokers": ["kraken", "coinbase", "kalshi"],
    "include_wallets": true,
    "force_live": true,
    "cache_ttl_seconds": 300,
    "fetch_timeout_seconds": 90,
    "timeout_seconds": 90,
    "broker_timeouts": { "kraken": 120 },
    "kraken_market_symbols": "BTC/USD,ETH/USD,SOL/USD,USD,USDC,USDT",
    "broker_routes": {
      "kraken": {
        "remote": false,
        "host": "local",
        "coinbot_root": "/Users/kevinreed/dev/coinbot",
        "instance_id": "paper_kraken_prop_starter_5k"
      },
      "coinbase": {
        "remote": true,
        "host": "kc-mini-lan",
        "coinbot_root": "/Users/kevinreed/dev/coinbot"
      },
      "kalshi": {
        "provider": "kalshi",
        "host": "local"
      }
    }
  },
  "wallets": {
    "enabled": false,
    "include_in_equity": true,
    "hot_cache_seconds": 90,
    "cold_cache_seconds": 600,
    "tx_limit": 12,
    "presets": []
  },
  "api_catalog": {
    "enabled": true
  },
  "assess": {
    "enabled": true,
    "model": "fast"
  },
  "receiver": {
    "enabled": true,
    "default_preset": "classic-rg",
    "webhooks": [
      {"id": "groq_net", "label": "GROQ", "url": "https://api.groq.com"},
      {"id": "openai_net", "label": "OAI", "url": "https://api.openai.com/v1/models"},
      {"id": "anthropic_net", "label": "ANTH", "url": "https://api.anthropic.com"},
      {"id": "mini_gw", "label": "MINI", "url": "http://Kevins-Mac-mini.local:3000/health/liveliness"}
    ]
  }
