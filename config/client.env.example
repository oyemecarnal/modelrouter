# Tower / agent clients — copy to runtime host.
# NO provider API keys here. Gateway host holds secrets.
#
#   cp config/client.env.example ~/.config/modelrouter/client.env
#   # Edit OPENAI_API_KEY — paste project virtual key from gateway host .env
#
# Agents and bots: source this or set in your process manager.

# ModelRouter gateway (always-on host)
# LAN / mDNS: http://gateway.local:3000/v1
# Linux without mDNS: http://100.64.0.1:3000/v1  (Tailscale — see config/hosts.yaml)
OPENAI_API_BASE=http://gateway.local:3000/v1
OPENAI_BASE_URL=http://gateway.local:3000/v1

# Auth — paste project virtual key from gateway .env (NOT a provider sk-proj key)
# Example project key env var on gateway: MODELROUTER_KEY_HERMES
# OPENAI_API_KEY=paste-from-gateway-env

# Policy presets — set per request or default in your agent config
# MODELROUTER_PRESET_ROUTINE=hermes-fast
# MODELROUTER_PRESET_COMPLEX=hermes-smart

# Do NOT set: GROQ_API_KEY, ANTHROPIC_API_KEY, etc. on remote runtime hosts.
