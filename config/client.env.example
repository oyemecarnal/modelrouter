# Tower / agent clients — copy to runtime host (kc-tower).
# NO provider API keys here. Gateway on kc-mini holds secrets.
#
#   cp config/client.env.example ~/.config/modelrouter/client.env
#
# Hermes, Kalshi, coinbot: source this or set in your process manager.

# ModelRouter gateway (always kc-mini on LAN)
OPENAI_API_BASE=http://kc-mini-lan:3000/v1
OPENAI_BASE_URL=http://kc-mini-lan:3000/v1

# Auth — project virtual key (same as MODELROUTER_MASTER_KEY in native mode until Docker+DB)
# Hermes example:
OPENAI_API_KEY=${MODELROUTER_KEY_HERMES:-see-mini-modelrouter-env}

# Policy presets — set per request or default in your agent config
# MODELROUTER_PRESET_ROUTINE=hermes-fast
# MODELROUTER_PRESET_COMPLEX=hermes-smart

# Do NOT set: OPENAI_API_KEY to sk-proj-..., GROQ_API_KEY, etc. on tower.
